# Public site URL (canonical, OG, emails, logo in messages)
VITE_SITE_URL=https://aurex-phi.vercel.app

# Branded HTML emails (recommended) — Vercel env vars:
RESEND_API_KEY=re_xxxxxxxx
CONTACT_TO_EMAIL=aurexitsolutions@gmail.com
RESEND_FROM=Aurex IT Solutions <onboarding@resend.dev>
# After verifying your domain at resend.com:
# RESEND_FROM=Aurex IT Solutions <hello@yourdomain.com>

# Optional: override API path (default /api/contact)
# VITE_CONTACT_API_URL=/api/contact
# Force branded API on local dev: VITE_CONTACT_USE_AUREX_API=true
# Skip branded API on production (Formspree only): VITE_CONTACT_USE_AUREX_API=false

# Fallback if Resend is not configured (plain Formspree email)
VITE_CONTACT_FORM_ENDPOINT=https://formspree.io/f/xeedlbzp
